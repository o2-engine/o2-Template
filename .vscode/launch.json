{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "JS Debugger: Attach",
            "type": "node",
            "request": "attach",
            "address": "localhost",
            "port": 5001,
            "localRoot": "${workspaceRoot}",
            "stopOnEntry": false
        },
        {
            "name": "Game (Mac, Debug)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Bin/Mac/Game",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/Bin/Mac",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "setupCommands": [
                {
                    "description": "Load o2 LLDB formatters",
                    "text": "command script import ${workspaceFolder}/o2/Framework/Platforms/o2_lldb_formatters.py",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cmake-build-game"
        },
        {
            "name": "Game (Windows, Debug)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Bin/Windows/Game.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/Bin/Windows",
            "environment": [],
            "console": "internalConsole",
            "visualizerFile": "${workspaceFolder}/o2/Framework/Platforms/Windows/Framework.natvis",
            "preLaunchTask": "cmake-build-game"
        },
        {
            "name": "Editor (Mac, Debug)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Bin/Mac/Editor",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/Bin/Mac",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "setupCommands": [
                {
                    "description": "Load o2 LLDB formatters",
                    "text": "command script import ${workspaceFolder}/o2/Framework/Platforms/o2_lldb_formatters.py",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cmake-build-editor"
        },
        {
            "name": "Editor (Windows, Debug)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Bin/Windows/Editor.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/Bin/Windows",
            "environment": [],
            "console": "internalConsole",
            "visualizerFile": "${workspaceFolder}/o2/Framework/Platforms/Windows/Framework.natvis",
            "preLaunchTask": "cmake-build-editor"
        },
        {
            "name": "GameTests (Mac, Debug)",
            "type": "cppdbg",
            "request": "launch",
