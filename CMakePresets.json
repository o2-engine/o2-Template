{
    "version": 6,
    "configurePresets": [
        {
            "name": "mac",
            "displayName": "Mac (Debug)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
                "CMAKE_Metal_COMPILER": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/metal",
                "O2_EDITOR": "ON",
                "O2_TESTS": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "mac-release",
            "displayName": "Mac (Release)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
                "CMAKE_Metal_COMPILER": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/metal",
                "O2_EDITOR": "ON",
                "O2_TESTS": "OFF"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "windows",
            "displayName": "Windows (Debug)",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "O2_EDITOR": "ON",
                "O2_TESTS": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-release",
            "displayName": "Windows (Release)",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "O2_EDITOR": "ON",
                "O2_TESTS": "OFF"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "linux",
            "displayName": "Linux (Debug)",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "O2_EDITOR": "ON",
                "O2_TESTS": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux (Release)",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "O2_EDITOR": "ON",
                "O2_TESTS": "OFF"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "ios-sim",
            "displayName": "iOS Simulator (Debug)",
            "generator": "Xcode",
            "binaryDir": "${sourceDir}/build-ios-sim",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "iOS",
                "CMAKE_OSX_SYSROOT": "iphonesimulator",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "14.0",
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
                "O2_EDITOR": "OFF",
                "O2_TESTS": "OFF"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "ios",
            "displayName": "iOS Device (Release)",
            "generator": "Xcode",
            "binaryDir": "${sourceDir}/build-ios",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "iOS",
                "CMAKE_OSX_SYSROOT": "iphoneos",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "14.0",
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
                "O2_EDITOR": "OFF",
                "O2_TESTS": "OFF"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "wasm",
            "displayName": "WebAssembly (Release, -O3 LTO SIMD)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-wasm",
            "environment": {
                "EMSDK": "$penv{HOME}$penv{USERPROFILE}/emsdk"
            },
            "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
                "O2_EDITOR": "OFF",
                "O2_TESTS": "OFF"
            },
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "wasm-windows",
            "inherits": "wasm",
            "displayName": "WebAssembly Windows (Release, -O3 LTO SIMD)",
            "environment": {
                "EMSDK": "$penv{USERPROFILE}/emsdk"
            },
            "cacheVariables": {
                "CMAKE_MAKE_PROGRAM": "$penv{USERPROFILE}/bin/ninja.exe"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "wasm-debug",
            "inherits": "wasm",
            "displayName": "WebAssembly (Debug, -O0 DWARF + safety checks)",
            "binaryDir": "${sourceDir}/build-wasm-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "wasm-debug-windows",
            "inherits": "wasm-windows",
            "displayName": "WebAssembly Windows (Debug, -O0 DWARF + safety checks)",
            "binaryDir": "${sourceDir}/build-wasm-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "android",
            "displayName": "Android (arm64-v8a, Debug)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-android",
            "environment": {
                "ANDROID_NDK_HOME": "$penv{HOME}/Library/Android/sdk/ndk/28.2.13676358"
            },
            "toolchainFile": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ANDROID_ABI": "arm64-v8a",
                "ANDROID_PLATFORM": "android-24",
                "ANDROID_STL": "c++_static",
                "O2_EDITOR": "OFF",
                "O2_TESTS": "OFF"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "android-release",
            "inherits": "android",
            "displayName": "Android (arm64-v8a, Release)",
            "binaryDir": "${sourceDir}/build-android-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "mac",
            "configurePreset": "mac",
            "configuration": "Debug"
        },
        {
            "name": "mac-release",
            "configurePreset": "mac-release",
            "configuration": "Release"
        },
        {
            "name": "windows",
            "configurePreset": "windows",
            "configuration": "Debug"
        },
        {
            "name": "windows-release",
            "configurePreset": "windows-release",
            "configuration": "Release"
        },
        {
            "name": "linux",
            "configurePreset": "linux",
            "configuration": "Debug"
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release",
            "configuration": "Release"
        },
        {
            "name": "ios-sim",
            "configurePreset": "ios-sim",
            "configuration": "Debug",
            "targets": ["Game"]
        },
        {
            "name": "ios",
            "configurePreset": "ios",
            "configuration": "Release",
            "targets": ["Game"]
        },
        {
            "name": "wasm",
            "configurePreset": "wasm",
            "configuration": "Release",
            "targets": ["Game"]
        },
        {
            "name": "wasm-windows",
            "configurePreset": "wasm-windows",
            "configuration": "Release",
            "targets": ["Game"]
        },
        {
            "name": "wasm-debug",
            "configurePreset": "wasm-debug",
            "configuration": "Debug",
            "targets": ["Game"]
        },
        {
            "name": "wasm-debug-windows",
            "configurePreset": "wasm-debug-windows",
            "configuration": "Debug",
            "targets": ["Game"]
        },
        {
            "name": "android",
            "configurePreset": "android",
            "configuration": "Debug",
            "targets": ["Game"]
        },
        {
            "name": "android-release",
            "configurePreset": "android-release",
            "configuration": "Release",
            "targets": ["Game"]
        }
    ]
}
